{
  "name": "react-tracescope",
  "version": "1.0.0",
  "packageManager": "pnpm@10.8.1",
  "description": "High-performance React component for visualizing AI agent execution traces with SSE streaming. Supports 5000+ nodes with virtual scrolling.",
  "main": "dist/tracescope.cjs.js",
  "module": "dist/tracescope.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tracescope.es.js",
      "require": "./dist/tracescope.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./integrations/langchain": {
      "import": "./dist/integrations/langchain/index.js",
      "require": "./dist/integrations/langchain/index.cjs.js",
      "types": "./dist/integrations/langchain/index.d.ts"
    },
    "./integrations/autogen": {
      "import": "./dist/integrations/autogen/index.js",
      "require": "./dist/integrations/autogen/index.cjs.js",
      "types": "./dist/integrations/autogen/index.d.ts"
    },
    "./integrations/dify": {
      "import": "./dist/integrations/dify/index.js",
      "require": "./dist/integrations/dify/index.cjs.js",
      "types": "./dist/integrations/dify/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "preinstall": "node -e \"if(!/pnpm/.test(process.env.npm_execpath||'')){console.error('Use pnpm instead of npm/yarn');process.exit(1)}\"",
    "dev": "vite",
    "dev:demo": "vite --config vite.demo.config.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "mock-server": "node src/mock-server/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "perf-test": "playwright test tests/perf.spec.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "trace",
    "visualization",
    "sse",
    "agent",
    "streaming",
    "react",
    "claude-code"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@storybook/builder-vite": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23",
    "@types/dompurify": "^3.0.5",
    "@types/highlight.js": "^9.12.4",
    "@types/marked": "^5.0.2",
    "classnames": "^2.5.1",
    "dompurify": "^3.4.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.0"
  }
}
