{
  "name": "react-tracescope",
  "version": "1.0.0",
  "description": "High-performance React component for visualizing AI agent execution traces with SSE streaming. Supports 5000+ nodes with virtual scrolling.",
  "main": "dist/tracescope.cjs.js",
  "module": "dist/tracescope.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tracescope.es.js",
      "require": "./dist/tracescope.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:demo": "vite --config vite.demo.config.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "mock-server": "node src/mock-server/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "perf-test": "playwright test perf.spec.ts"
  },
  "keywords": [
    "trace",
    "visualization",
    "sse",
    "agent",
    "streaming",
    "react",
    "claude-code"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.0",
    "playwright": "^1.59.1",
    "puppeteer": "^24.41.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23",
    "@types/dompurify": "^3.0.5",
    "@types/highlight.js": "^9.12.4",
    "@types/marked": "^5.0.2",
    "cors": "^2.8.6",
    "dompurify": "^3.4.0",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.0"
  }
}
