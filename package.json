{
  "name": "agent-sse-flow",
  "version": "2.2.0",
  "packageManager": "pnpm@10.8.1",
  "description": "Agent SSE Stream Visualizer - A lightweight React component. Free, unlimited, local.",
  "main": "dist/agent-sse-flow.cjs.js",
  "module": "dist/agent-sse-flow.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/agent-sse-flow.es.js",
      "require": "./dist/agent-sse-flow.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "build:demo": "vite build --config vite.demo.config.ts",
    "mock-server": "node src/mock-server/index.mjs",
    "perf-test": "playwright test tests/perf.spec.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent",
    "sse",
    "flow",
    "visualization",
    "streaming",
    "react",
    "langgraph",
    "langchain",
    "langsmith-alternative"
  ],
  "author": "afine907",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afine907/agent-sse-flow.git"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "jsdom": "^29.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "react-markdown": "^10.1.0"
  }
}
