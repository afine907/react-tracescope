{
  "name": "agent-sse-flow",
  "version": "2.0.0",
  "description": "Agent SSE Stream Visualizer - A lightweight React component. Free, unlimited, local.",
  "main": "dist/agent-sse-flow.cjs.js",
  "module": "dist/agent-sse-flow.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/agent-sse-flow.es.js",
      "require": "./dist/agent-sse-flow.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent",
    "sse",
    "flow",
    "visualization",
    "streaming",
    "react",
    "langgraph",
    "langchain",
    "langsmith-alternative"
  ],
  "author": "afine907",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/afine907/react-tracescope"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
